# ============================================
# Environment Variables - Copy to .env
# ============================================

# PostgreSQL Connection (LOCAL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/malnutrition_db

# OR use Neon/Supabase (cloud):
# DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# Session Secret (change to random string in production)
SESSION_SECRET=change_this_to_a_random_secret_string

# Node Environment
NODE_ENV=development

# Port
PORT=5000
